# The Dojo Bay — onion-only nginx config.
# nginx binds to localhost ONLY; the Tor daemon maps the hidden service's
# port 80 onto it (see the HiddenServicePort line in the README). Nothing is
# exposed on the machine's public IP except SSH.
#
# Install:
#   sudo cp deploy/nginx-onion.conf.example /etc/nginx/sites-available/dojobay
#   sudo ln -s /etc/nginx/sites-available/dojobay /etc/nginx/sites-enabled/
#   sudo rm -f /etc/nginx/sites-enabled/default
#   sudo nginx -t && sudo systemctl reload nginx
server {
    listen 127.0.0.1:8080;
    server_name _;
    root /var/www/dojobay;
    index index.html;

    gzip on;
    gzip_types text/css text/javascript application/javascript application/json image/svg+xml text/markdown;

    # The directory data is rewritten every 10 minutes — keep it fresh.
    location /data/ {
        add_header Cache-Control "max-age=60";
        default_type application/json;
    }

    # Static assets and fonts can be cached for a day.
    # Code and markup must revalidate so a deploy shows up immediately.
    location ~* \.(html|js|css|md)$ {
        add_header Cache-Control "no-cache";
    }

    # Large, rarely-changing assets can be cached for a day.
    location ~* \.(woff2|png|svg|ico)$ {
        add_header Cache-Control "max-age=86400";
    }

    # --- self-service backend (Auth47 submission API) ---
    location /api/ {
        proxy_pass http://127.0.0.1:8787;
        proxy_set_header Host $host;
        proxy_read_timeout 45s;   # the connection gate + PayNym lookup probe Tor
    }

    # SECURITY: the backend's data (store.json: sessions, payment codes, node
    # API keys) and source live under server/ inside the web root. Never serve
    # them over the onion.
    location ^~ /server/ { return 404; }

    # Serve the SPA shell for the admin route (client-side view; auth is enforced
    # by the backend, this only returns the same HTML/JS).
    location = /admin { try_files /index.html =404; }

    location / {
        try_files $uri $uri/ =404;
    }
}
