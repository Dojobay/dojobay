# Install to /etc/systemd/system/dojobay-update.timer then:
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now dojobay-update.timer
[Unit]
Description=Run The Dojo Bay updater every 10 minutes

[Timer]
OnBootSec=2min
OnUnitActiveSec=10min
AccuracySec=30s
Persistent=true

[Install]
WantedBy=timers.target
